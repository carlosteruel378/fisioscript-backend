# ─────────────────────────────────────────────────────────────
# FisioScript — Variables de entorno
# Copia este archivo a ".env" y rellena los valores reales.
# NUNCA subas el .env real a GitHub ni a ningún sitio público.
# ─────────────────────────────────────────────────────────────

# Puerto del servidor local (déjalo en 3001; el frontend lo busca ahí)
PORT=3001

# ── Groq (IA: análisis clínico + transcripción Whisper) ──────
# La MISMA clave que tienes en Railway. Cópiala de Railway → Variables.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://lgryxctfabqlubztmenb.supabase.co
# SERVICE KEY (la secreta, NO la anon).
# Supabase → Project Settings → API → service_role (Reveal)
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxx

# ── Stripe ───────────────────────────────────────────────────
# Para pruebas LOCALES usa las claves de TEST (sk_test_...), nunca las de producción.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Price IDs (en local, los de TEST)
PRICE_INDIVIDUAL_MONTHLY=price_xxxx
PRICE_INDIVIDUAL_ANNUAL=price_xxxx
PRICE_CLINICA_MONTHLY=price_xxxx
PRICE_CLINICA_ANNUAL=price_xxxx
PRICE_EXTRA_SEAT=price_xxxx

# ── Sentry (observabilidad / alertas de errores) ─────────────
# En local déjalo VACÍO para no recibir alertas de pruebas.
SENTRY_DSN=
