# ─────────────────────────────────────────────
# FisioScript — Variables de entorno
# ─────────────────────────────────────────────
# Copia este archivo, renómbralo a .env
# y rellena los valores reales.
# NUNCA subas el .env real a GitHub.
# ─────────────────────────────────────────────

# API key de Groq (gratuita en console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL de tu frontend (para CORS en producción)
# En local puedes dejarlo vacío
FRONTEND_URL=https://fisioscript.com

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3001
